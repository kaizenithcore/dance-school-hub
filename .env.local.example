# IMPORTANT: Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_SERVICE_ROLE_KEY=

# Backend API URL
# Local development: http://localhost:3000
# Production: https://your-backend-api.com
VITE_API_URL=http://localhost:3000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
VITE_STRIPE_PRICE_STARTER=price_xxx
VITE_STRIPE_PRICE_PRO=price_xxx
VITE_STRIPE_PRICE_ENTERPRISE=price_xxx

# Optional providers (used by advanced modules)
# Resend: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
